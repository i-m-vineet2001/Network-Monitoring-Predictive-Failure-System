   "outputs": [],
   "source": [
    "# Install any missing libraries\n",
    "!pip install scikit-learn pandas matplotlib seaborn --quiet\n",
    "\n",
    "# ── Imports ───────────────────────────────────────────────\n",
    "import pandas as pd\n",
